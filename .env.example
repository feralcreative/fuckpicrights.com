# Copy to .env and fill in the token. .env is gitignored — never commit it.
# Read by utils/deploy/prod.sh for the post-deploy Cloudflare cache purge.

# Cloudflare API token with the Zone.Cache Purge permission.
# Shared Feral Creative account token — see another feral repo's .env
# (e.g. feral/3d.feralcreative.co/.env) or the Cloudflare dashboard.
CLOUDFLARE_API_TOKEN=

# fuckpicrights.com zone, on the Feral Creative account (not secrets — just IDs).
CLOUDFLARE_ZONE_ID=94cbda56ab945bfaf227cab26280c323
CLOUDFLARE_ACCOUNT_ID=30aa05fc7822ef63635046e5c7771a9a

# Optional: override SSH key path (default: auto-detect ~/.ssh/id_ed25519, then id_rsa, then ssh-agent)
# SSH_KEY_PATH=
